# Job Intelligent - Environment Variables Template
# Copy this file as .env and update values

# Database
DATABASE_URL=postgresql://jobintel:jobintel@localhost:5432/jobintel_db

# JWT
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Application
DEBUG=True
CORS_ORIGINS=["*"]

# Recommender
EMBEDDING_MODEL=all-MiniLM-L6-v2
